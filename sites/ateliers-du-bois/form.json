      "options": [
        "Dressing",
        "Cuisine",
        "Meuble d'entrée",
        "Meuble sous escalier",
        "Meuble TV",
        "Bibliothèque / Etagère",
        "Aménagement de garage",
        "Aménagement pour bureau",
        "Un autre projet"
      ]
    },
    {
      "name": "prenom",
      "label": "Votre prénom",
      "type": "text",
      "required": false
    },
    {
      "name": "nom",
      "label": "Votre nom",
      "type": "text",
      "required": true
    },
    {
      "name": "email",
      "label": "Adresse e-mail",
      "type": "email",
      "required": true
    },
    {
      "name": "telephone",
      "label": "Téléphone",
      "type": "tel",
      "required": true,
      "help": "Indispensable pour convenir d'un RDV"
    },
    {
      "name": "code_postal",
      "label": "Code postal",
      "type": "text",
      "required": true
    },
    {
